# MANIFEST.in — sdist scope control (S-059, 2026-05-15).
#
# Without these directives, setuptools' default sdist scope auto-
# includes any top-level `tests/` directory that's tracked in git
# (it scans for typical project layouts and pulls in tests/ + a few
# other common dev dirs).
#
# For arbez that meant v0.0.35's sdist shipped all `tests/test_*.py`
# files to TestPyPI — leaking internal test names + comments without
# even shipping the `conftest.py` / `_corpus.py` fixtures the tests
# need to actually run. Worst of both worlds.
#
# The wheel is unaffected by this file — wheels only include what
# `[tool.setuptools.packages.find]` resolves under `src/`, which is
# strictly the `arbez` package + its `_assets/` data files.
#
# What the sdist SHOULD ship (and only this):
#   - pyproject.toml, README.md, LICENSE, NOTICE (top-level metadata)
#   - src/arbez/** (package source + bundled model + per-asset
#     LICENSE/NOTICE)
#   - Auto-generated by setuptools: PKG-INFO, setup.cfg, egg-info
#
# Everything else is dev-only / internal-only. We list the prunes
# explicitly even where setuptools' current default would already
# skip them (e.g. `docs/`), so future setuptools default changes
# can't accidentally widen the sdist surface.

# ── Test suite (DO NOT ship — leaked in v0.0.35; S-059) ────────────
prune tests

# ── Dev tooling (internal-only) ────────────────────────────────────
prune tools
prune constraints

# ── Internal documentation (lives in the repo for maintainers) ─────
# Note: README.md at repo root IS shipped (referenced by pyproject's
# `readme` field). It's the clean public-facing README from S-058.
# Everything under docs/ — including docs/README-INTERNAL.md, the
# api-reference / concepts / how-to / etc. — stays internal-only.
prune docs

# ── Reference examples (clutter on PyPI, also reference internal
# corpus paths) ────────────────────────────────────────────────────
prune examples

# ── Repository / CI configuration (S-043, S-045, S-051, S-056) ─────
prune .github

# ── Top-level dev-only files ───────────────────────────────────────
exclude .gitignore
exclude CHANGELOG.md
exclude CONTRIBUTING.md
exclude DECISIONS.md
exclude MANIFEST.in

# ── S-064: bundled-model provenance manifest ───────────────────────
# Written by ``tools/sync_bundled_model.py``; consumed by the
# release-workflow manifest-verify step. Lives at the repo root so
# CI can verify the bundled ONNX sha256/size at release time without
# descending into ``tools/`` (which is also excluded from sdist).
# Excluded from the sdist as a dev/CI artifact.
exclude bundled_model.lock.json
